{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "teacher": "dotenv -e .env.teacher nodemon server.js",
    "student": "dotenv -e .env.student nodemon server.js",
    "servernode": "dotenv -e .env.server nodemon server.js",
    "unauthorized": "dotenv -e .env.unauthorized nodemon server.js",
    "ngrok:all": "npx --yes ngrok start --all --config=ngrok.yml",
    "ngrok:teacher": "npx --yes ngrok http 4000",
    "ngrok:student": "npx --yes ngrok http 3001",
    "ngrok:servernode": "npx --yes ngrok http 5000",
    "ngrok:blockchain": "npx --yes ngrok http 8545",
    "start:all": "npx --yes concurrently \"npm run teacher\" \"npm run student\" \"npm run servernode\" \"npm run unauthorized\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}